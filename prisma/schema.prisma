generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Department {
  id               String             @id @default(uuid())
  name             String             @unique
  emailGroup       String?
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  darDistributions DarDistribution[]
  darMasters       DarMaster[]
  users            User[]
  docControls      DocumentControl[]
  docCategories    DocumentCategory[]

  @@map("Department")
}

model User {
  id                    String                    @id @default(uuid())
  employeeId            String?                   @unique
  msUserId              String?                   @unique
  name                  String?
  email                 String                    @unique
  emailVerified         DateTime?
  image                 String?
  role                  UserRole                  @default(USER)
  position              String?
  savedSignatureUrl     String?
  signatureType         SignatureType?
  departmentId          String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  announcements       Announcement[]
  darApprovals        DarApproval[]
  darAttachments      DarAttachment[]
  darMasters          DarMaster[]
  qmsProcessings      QmsProcessing[]
  approvalSignatures ApprovalSignature[]
  docControlsCreated  DocumentControl[]         @relation("DocCreatedBy")
  docControlsUpdated  DocumentControl[]         @relation("DocUpdatedBy")
  docRevisionsCreated DocumentControlRevision[] @relation("DocRevCreatedBy")
  department          Department?               @relation(fields: [departmentId], references: [id])

  @@index([role])
  @@index([departmentId])
  @@map("User")
}

model SystemConfig {
  configKey   String   @id
  configValue String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("SystemConfig")
}

model Announcement {
  id                  String      @id @default(uuid())
  sourceSystem        String
  title               String
  content             String
  displayType         DisplayType @default(LIST)
  pushToCompanyCenter Boolean     @default(false)
  expiryDate          DateTime?
  startDate           DateTime?
  endDate             DateTime?
  spItemId            String?
  spWebUrl            String?
  spDownloadUrl       String?
  fileName            String?
  mimeType            String?
  bgColor             String?
  bgImageUrl          String?
  bgImageSpId         String?
  textColor           String?
  status              String      @default("ACTIVE")
  createdById         String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  createdBy           User        @relation(fields: [createdById], references: [id])

  @@map("Announcement")
}

model DarMaster {
  id            String            @id @default(uuid())
  darNo         String?           @unique
  requestDate   DateTime          @default(now())
  objective     String
  docType       String
  docTypeOther  String?
  reason        String
  spFolderId    String?
  spFolderPath  String?
  spDriveId     String?
  spItemId      String?
  spWebUrl      String?
  status        DarStatus         @default(DRAFT)
  requesterId   String
  departmentId  String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  approvals     DarApproval[]
  attachments   DarAttachment[]
  distributions DarDistribution[]
  items         DarItem[]
  department    Department        @relation(fields: [departmentId], references: [id])
  requester     User              @relation(fields: [requesterId], references: [id])
  qmsProcessing QmsProcessing?

  @@index([status])
  @@index([requesterId])
  @@index([departmentId])
  @@map("DarMaster")
}

model DarItem {
  id          String    @id @default(uuid())
  itemNo      Int
  docNumber   String
  docName     String
  revision    String
  darMasterId String
  darMaster   DarMaster @relation(fields: [darMasterId], references: [id], onDelete: Cascade)

  @@map("DarItem")
}

model DarDistribution {
  id           String     @id @default(uuid())
  darMasterId  String
  departmentId String
  darMaster    DarMaster  @relation(fields: [darMasterId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id])

  @@map("DarDistribution")
}

model DarAttachment {
  id            String    @id @default(uuid())
  fileName      String
  fileSize      Int
  mimeType      String
  spItemId      String
  spWebUrl      String
  spDownloadUrl String
  folderPath    String
  darMasterId   String
  uploadedById  String
  createdAt     DateTime  @default(now())
  darMaster     DarMaster @relation(fields: [darMasterId], references: [id], onDelete: Cascade)
  uploadedBy    User      @relation(fields: [uploadedById], references: [id])

  @@index([darMasterId])
  @@index([spItemId])
  @@map("DarAttachment")
}

model DarApproval {
  id                String         @id @default(uuid())
  stepRole          ApprovalStep
  action            ApprovalAction @default(PENDING)
  actionDate        DateTime?
  signatureUsedUrl  String?
  signatureTypeUsed SignatureType?
  darMasterId       String
  assignedUserId    String
  comment           String?
  assignedUser      User           @relation(fields: [assignedUserId], references: [id])
  darMaster         DarMaster      @relation(fields: [darMasterId], references: [id], onDelete: Cascade)

  @@index([darMasterId])
  @@index([assignedUserId])
  @@map("DarApproval")
}

model ApprovalSignature {
  id            String         @id @default(uuid())
  module        ApprovalModule
  documentId    String
  step          ApprovalStep
  action        ApprovalAction @default(PENDING)
  actionDate    DateTime?
  signerUserId  String
  signaturePath String?
  comment       String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  signerUser    User           @relation(fields: [signerUserId], references: [id])

  @@index([module, documentId])
  @@index([signerUserId])
  @@unique([module, documentId, step])
  @@map("ApprovalSignature")
}

model QmsProcessing {
  id                    String    @id @default(uuid())
  chkHasAttachment      Boolean   @default(false)
  chkPrintAndValidate   Boolean   @default(false)
  chkRenumber           Boolean   @default(false)
  chkImpactInvestigated Boolean   @default(false)
  chkSubmitVerification Boolean   @default(false)
  chkGetBackProcess     Boolean   @default(false)
  chkCopyDistribute     Boolean   @default(false)
  comments              String?
  processDate           DateTime?
  darMasterId           String    @unique
  qmsUserId             String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  darMaster             DarMaster @relation(fields: [darMasterId], references: [id], onDelete: Cascade)
  qmsUser               User      @relation(fields: [qmsUserId], references: [id])

  @@map("QmsProcessing")
}

model PublicDocument {
  id            String   @id @default(uuid())
  darMasterId   String?
  docNumber     String
  docName       String
  revision      String
  spDriveId     String
  spItemId      String
  spFolderPath  String?
  spWebUrl      String
  publishedDate DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("PublicDocument")
}

model KPI {
  id                String             @id @default(uuid())
  yearly            Int
  department        String
  prepare           String
  reviewer          String
  approver          String
  status            KpiObjectiveStatus @default(DRAFT)
  prepareSignature  String?            @map("prepare_signature") @db.Text
  reviewerUserId    String?            @map("reviewer_user_id")
  approverUserId    String?            @map("approver_user_id")
  submittedAt       DateTime?          @map("submitted_at")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  objectives        KPIObjective[]
  monthlyReports    KPIMonthlyReport[]

  @@map("kpis")
}

model KPIObjective {
  id                   String             @id @default(uuid())
  kpiId                String             @map("kpi_id")
  target               Float
  objective            String             @db.Text
  frequency            String
  calculationFormula   String             @map("calculation_formula") @db.Text
  actionPlanGuidelines String             @map("action_plan_guidelines") @db.Text
  referenceDocuments   String?            @map("reference_documents") @db.Text
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  kpi                  KPI                @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  monthlyDetails       KPIMonthlyDetail[]

  @@map("kpi_objectives")
}

model KPIMonthlyReport {
  id          String             @id @default(uuid())
  kpiId       String             @map("kpi_id")
  month       String
  year        Int
  status      MonthlyStatus      @default(DRAFT)
  prepareBy   String?            @map("prepare_by")
  reviewBy    String?            @map("review_by")
  approveBy   String?            @map("approve_by")
  submittedAt DateTime?          @map("submitted_at")
  approvedAt  DateTime?          @map("approved_at")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  kpi         KPI                @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  details     KPIMonthlyDetail[]

  @@unique([kpiId, month, year])
  @@map("kpi_monthly_reports")
}

model KPIMonthlyDetail {
  id                String                @id @default(uuid())
  monthlyReportId   String                @map("monthly_report_id")
  kpiObjectiveId    String                @map("kpi_objective_id")
  actualResult      Float?                @map("actual_result")
  achievedStatus    AchievedStatus        @default(PENDING)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  monthlyReport     KPIMonthlyReport      @relation(fields: [monthlyReportId], references: [id], onDelete: Cascade)
  kpiObjective      KPIObjective          @relation(fields: [kpiObjectiveId], references: [id], onDelete: Restrict)
  correctiveActions KPICorrectiveAction[]

  @@unique([monthlyReportId, kpiObjectiveId])
  @@map("kpi_monthly_details")
}

model KPICorrectiveAction {
  id                String           @id @default(uuid())
  monthlyDetailId   String           @map("monthly_detail_id")
  times             Int
  rootCause         String           @map("root_cause") @db.Text
  guidelines        String           @db.Text
  responsiblePerson String           @map("responsible_person")
  dueDate           DateTime         @map("due_date")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  monthlyDetail     KPIMonthlyDetail @relation(fields: [monthlyDetailId], references: [id], onDelete: Cascade)

  @@map("kpi_corrective_actions")
}

enum UserRole {
  USER
  IT
  QMS
  MR
}

enum DisplayType {
  LIST
  SCROLLING
  BANNER
}

enum DarStatus {
  DRAFT
  PENDING_REVIEW
  PENDING_APPROVE
  QMS_PROCESSING
  COMPLETED
  CANCELLED
}

enum ApprovalAction {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalStep {
  REQUESTER
  REQUESTER_MANAGER
  PREPARER
  REVIEWER
  APPROVER
  APPROVER_MR
  APPROVER_DCC
  QMS_PROCESSOR
}

enum ApprovalModule {
  DAR
  KPI
  KPI_MONTHLY
}

enum SignatureType {
  DRAW
  TYPE
  IMAGE
}

enum KpiObjectiveStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum MonthlyStatus {
  DRAFT
  PENDING_REVIEW
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum AchievedStatus {
  PENDING
  OK
  NOT_OK
}

model DocumentControl {
  id            String           @id @default(uuid())
  docNumber     String           @unique
  docName       String
  revision      String?
  description   String?
  status        DocControlStatus @default(DRAFT)
  effectiveDate DateTime?
  spDriveId     String?
  spItemId      String?
  spWebUrl      String?
  spDownloadUrl String?
  spFolderPath  String?
  fileName      String?
  fileSize      Int?
  mimeType      String?
  createdById   String
  updatedById   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Relations
  createdBy    User                      @relation("DocCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?                     @relation("DocUpdatedBy", fields: [updatedById], references: [id])
  departmentId String?
  department   Department?               @relation(fields: [departmentId], references: [id])
  categoryId   String?
  category     DocumentCategory?         @relation(fields: [categoryId], references: [id])
  revisions    DocumentControlRevision[]

  @@index([status])
  @@index([categoryId])
  @@index([createdById])
  @@index([departmentId])
  @@map("DocumentControl")
}

model DocumentCategory {
  id           String   @id @default(uuid())
  name         String
  description  String?
  order        Int      @default(0)
  departmentId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department        @relation(fields: [departmentId], references: [id])
  documents  DocumentControl[]

  @@index([departmentId])
  @@map("DocumentCategory")
}

model DocumentControlRevision {
  id                String           @id @default(uuid())
  documentControlId String
  revision          String
  effectiveDate     DateTime?
  status            DocControlStatus @default(ACTIVE)
  spDriveId         String?
  spItemId          String?
  spWebUrl          String?
  spDownloadUrl     String?
  spFolderPath      String?
  fileName          String?
  fileSize          Int?
  mimeType          String?
  createdById       String
  createdAt         DateTime         @default(now())

  // Relations
  documentControl DocumentControl @relation(fields: [documentControlId], references: [id], onDelete: Cascade)
  createdBy       User            @relation("DocRevCreatedBy", fields: [createdById], references: [id])

  @@index([documentControlId])
  @@index([status])
  @@map("DocumentControlRevision")
}

enum DocControlStatus {
  DRAFT
  ACTIVE
  OBSOLETE
}
