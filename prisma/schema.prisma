generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

generator client_edge {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma/edge"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}
enum UserRole {
  USER
  IT
  QMS
  MR
}

enum DisplayType {
  LIST
  SCROLLING
}

enum DarStatus {
  DRAFT
  PENDING_REVIEW
  PENDING_APPROVE
  QMS_PROCESSING
  COMPLETED
  CANCELLED
}

enum ApprovalAction {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalStep {
  PREPARER
  REVIEWER
  APPROVER_MR
}

// [NEW] Enum สำหรับประเภทการเซ็น
enum SignatureType {
  DRAW   // ลากเส้นด้วยเมาส์/นิ้ว
  TYPE   // พิมพ์ข้อความ
  IMAGE  // อัปโหลดรูปภาพ
}

enum KpiPeriodType {
  YEARLY
  QUARTERLY
}

enum KpiMonthlyStatus {
  OK
  NG
  PENDING
}

enum KpiApprovalStatus {
  DRAFT       // แผนกกำลังบันทึกข้อมูล/ยังกรอกไม่เสร็จ
  SUBMITTED   // แผนกกดส่งข้อมูลแล้ว (รอหัวหน้าแผนก Review)
  REVIEWED    // หัวหน้าแผนกตรวจสอบแล้ว (รอ QMS ทบทวนความถูกต้อง)
  VERIFIED    // QMS สอบทานผ่านเรียบร้อย (ข้อมูลถูกแช่แข็ง Lock ห้ามแก้ไขประจำเดือน)
  REJECTED    // เอกสารโดนตีกลับให้แก้ไขข้อมูลผลงานใหม่
}

enum KpiApprovalStep {
  PREPARER
  REVIEWER
  QMS_VERIFIER
}

// ==========================================
// 1. NextAuth.js Standard Models (สำหรับ M365 Login)
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// 2. Organization & Users Models (ผู้ใช้งานและแผนก)
// ==========================================

model Department {
  id        String   @id @default(cuid())
  name      String   @unique // เช่น 'HR', 'IT', 'QMS', 'QC'
  emailGroup   String? 
  isActive  Boolean  @default(true)

  // Relations
  users               User[]
  darRequests         DarMaster[]        @relation("DarDepartment")
  darDistributions    DarDistribution[]

  kpiMasters       KpiMaster[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id                String    @id @default(cuid())
  employeeId        String?   @unique // [Company Center] รหัสพนักงาน ใช้ Login หน้าแรก
  msUserId          String?   @unique // [M365] Object ID ของ User ใน Entra ID
  name              String?
  email             String    @unique
  emailVerified     DateTime?
  image             String?
  role              UserRole  @default(USER)

  // --- [NEW] ระบบบันทึกลายเซ็นเพื่อใช้ครั้งหน้า ---
  savedSignatureUrl String?   @db.Text       // เก็บ URL รูปลายเซ็น (Base64 หรือ Cloud URL)
  signatureType     SignatureType?           // ประเภทลายเซ็นที่เซฟไว้
  // ---------------------------------------------
  kpiApprovals      KpiApprovalLog[] @relation("KpiAssignedApprover")

  // Relations
  departmentId      String?
  department        Department? @relation(fields: [departmentId], references: [id])
  
  accounts          Account[]
  sessions          Session[]

  // QMS Relations
  createdAnnouncements Announcement[]
  darRequests          DarMaster[]     @relation("DarRequester")
  darApprovals         DarApproval[]   @relation("AssignedApprover")
  darAttachments       DarAttachment[] @relation("DarAttachmentUploader")
  qmsProcessings       QmsProcessing[] @relation("QmsOfficer")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemConfig {
  configKey   String @id // เช่น 'CURRENT_MR_USER_ID'
  configValue String
  description String?
  
  updatedAt   DateTime @updatedAt
}

// ==========================================
// 3. Announcement Module (ระบบประกาศ)
// ==========================================

model Announcement {
  id                  String      @id @default(cuid())
  sourceSystem        String      // 'QMS', 'HR', 'GA'
  title               String
  content             String      @db.Text
  displayType         DisplayType @default(LIST)
  pushToCompanyCenter Boolean     @default(false)
  expiryDate          DateTime?   

  // --- [NEW] Date and Attachments ---
  startDate           DateTime?
  endDate             DateTime?
  spItemId            String?
  spWebUrl            String?     @db.Text
  spDownloadUrl       String?     @db.Text
  fileName            String?
  mimeType            String?
  // ---------------------------------

  // Relations
  createdById         String
  createdBy           User        @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 4. DAR Module (ระบบจัดการเอกสาร)
// ==========================================

model DarMaster {
  id             String    @id @default(cuid())
  darNo          String?   @unique // สร้างเมื่อ Submit เช่น DAR-2026-001
  requestDate    DateTime  @default(now())
  
  objective      String    // Prepare new, Revise, Cancel etc.
  docType        String    // Manual, Format, Procedure etc.
  docTypeOther   String?   // กรณีระบุอื่นๆ
  reason         String    @db.Text
  
  // --- [SharePoint Integration] สำหรับเอกสารแบบร่าง ---
  spFolderId     String?   
  spFolderPath   String?   // เช่น "Drafts/DAR-2026-001"
  spDriveId      String?   
  spItemId       String?   
  spWebUrl       String?   // ลิงก์สำหรับพรีวิวบนเบราว์เซอร์
  // ---------------------------------------------------

  status         DarStatus @default(DRAFT)

  // Relations
  requesterId    String
  requester      User      @relation("DarRequester", fields: [requesterId], references: [id])
  
  departmentId   String
  department     Department @relation("DarDepartment", fields: [departmentId], references: [id])

  items          DarItem[]
  distributions  DarDistribution[]
  approvals      DarApproval[]
  attachments    DarAttachment[]
  qmsProcessing  QmsProcessing?

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model DarItem {
  id          String   @id @default(cuid())
  itemNo      Int
  docNumber   String
  docName     String
  revision    String

  // Relations
  darMasterId String
  darMaster   DarMaster @relation(fields: [darMasterId], references: [id], onDelete: Cascade)
}

model DarDistribution {
  id           String   @id @default(cuid())

  // Relations
  darMasterId  String
  darMaster    DarMaster  @relation(fields: [darMasterId], references: [id], onDelete: Cascade)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
}

model DarAttachment {
  id            String   @id @default(cuid())
  fileName      String                    // original file name
  fileSize      Int                       // bytes
  mimeType      String
  spItemId      String                    // SharePoint driveItem id
  spWebUrl      String   @db.Text        // browser preview URL
  spDownloadUrl String   @db.Text        // direct download URL
  folderPath    String                    // e.g. DAR/QMS/PREPARE_NEW/SOP

  // Relations
  darMasterId   String
  darMaster     DarMaster @relation(fields: [darMasterId], references: [id], onDelete: Cascade)

  uploadedById  String
  uploadedBy    User      @relation("DarAttachmentUploader", fields: [uploadedById], references: [id])

  createdAt     DateTime  @default(now())
}

// ==========================================
// 5. Workflow & E-Signature Module (ระบบเซ็นอนุมัติ)
// ==========================================

model DarApproval {
  id                String         @id @default(cuid())
  stepRole          ApprovalStep   // PREPARER, REVIEWER, APPROVER_MR
  action            ApprovalAction @default(PENDING)
  actionDate        DateTime?      // ประทับเวลาอัตโนมัติ

  // --- [NEW] ลายเซ็นเฉพาะสำหรับใบ DAR นี้ (ป้องกันอดีตเปลี่ยนเมื่อ User เปลี่ยนลายเซ็นใหม่) ---
  signatureUsedUrl  String?        @db.Text // รูปลายเซ็นที่ถูกใช้จริงในวินาทีที่กด Approve
  signatureTypeUsed SignatureType?          // ประเภทการเซ็นที่ใช้ (DRAW, TYPE, IMAGE)
  // --------------------------------------------------------------------------------

  // Relations
  darMasterId       String
  darMaster         DarMaster @relation(fields: [darMasterId], references: [id], onDelete: Cascade)
  
  assignedUserId    String
  assignedUser      User      @relation("AssignedApprover", fields: [assignedUserId], references: [id])
}

// ==========================================
// 6. QMS Processing & Document Control (ส่วนเจ้าหน้าที่)
// ==========================================

model QmsProcessing {
  id                    String    @id @default(cuid())
  
  // Checklist Options (Boolean)
  chkHasAttachment      Boolean   @default(false)
  chkPrintAndValidate   Boolean   @default(false)
  chkRenumber           Boolean   @default(false)
  chkImpactInvestigated Boolean   @default(false)
  chkSubmitVerification Boolean   @default(false)
  chkGetBackProcess     Boolean   @default(false)
  chkCopyDistribute     Boolean   @default(false)
  
  comments              String?   @db.Text
  processDate           DateTime? 

  // Relations
  darMasterId           String    @unique
  darMaster             DarMaster @relation(fields: [darMasterId], references: [id], onDelete: Cascade)
  
  qmsUserId             String
  qmsUser               User      @relation("QmsOfficer", fields: [qmsUserId], references: [id])

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model PublicDocument {
  id             String    @id @default(cuid())
  darMasterId    String?   
  docNumber      String
  docName        String
  revision       String
  
  // --- [SharePoint Integration] สำหรับเอกสารฉบับจริง (เซ็นครบแล้ว) ---
  spDriveId      String    
  spItemId       String    // ใช้ทำปุ่ม Download
  spFolderPath   String?   // พาร์ท เช่น "IT/SOP"
  spWebUrl       String    
  // -----------------------------------------------------------

  publishedDate  DateTime  @default(now())

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ==========================================
// 7. KPI Module (ระบบตัวชี้วัดและมาตรการแก้ไข)
// ==========================================

model KpiSchedule {
  id        String   @id @default(cuid())
  year      Int
  month     Int      // 1 ถึง 12
  dueDate   DateTime // วันที่เจ้าหน้าที่ QMS กำหนดให้เดดไลน์ในการส่งผลงานแต่ละเดือน
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month]) // ป้องกันการสร้างเงื่อนไขซ้ำซ้อนในเดือนเดียวกัน
}

model KpiMaster {
  id                   String            @id @default(cuid())
  year                 Int               // เช่น 2026
  periodType           KpiPeriodType     @default(YEARLY) // รองรับขยายตัวเป็น QUARTERLY ในอนาคต
  objectiveDetails     String            @db.Text // วัตถุประสงค์และเป้าหมาย (เช่น "การทำงานของระบบ")
  measurementFrequency String            @default("Every Month") // หรือระบุตามเงื่อนไขบริษัท
  calculationFormula   String?           @db.Text // สูตรการคำนวณ
  guidelines           String?           @db.Text // แนวทางในการดำเนินการ
  trackingRecords      String?           @db.Text // บันทึก/ข้อมูลที่ใช้ในการติดตาม
  targetValue          Decimal           @db.Decimal(5, 2) // เช่น 95.00, 99.00

  // Relations
  departmentId         String
  department           Department        @relation(fields: [departmentId], references: [id])
  
  monthlyResults       KpiMonthlyResult[]
  approvalLogs         KpiApprovalLog[]

  createdById          String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
}

model KpiMonthlyResult {
  id              String            @id @default(cuid())
  month           Int               // 1 ถึง 12
  actualValue     Decimal?          @db.Decimal(5, 2) // ค่า % ผลงาน หรือ NULL หากระบุเป็น N/A
  isNa            Boolean           @default(false)   // ตัวติ๊กกรณีไม่มีกิจกรรมในเดือนนั้น
  status          KpiMonthlyStatus  @default(PENDING) // OK หรือ NG ประมวลผลอัตโนมัติหลังบันทึก
  approvalStatus  KpiApprovalStatus @default(DRAFT)   // ตัวคุม State Machine หน้าบ้าน

  // --- [SharePoint Integration] สำหรับเก็บไฟล์แนบหลักฐานผลงานรายเดือน ---
  spItemId        String?
  spWebUrl        String?           @db.Text // ลิงก์สำหรับพรีวิวดูบนเบราว์เซอร์
  spDownloadUrl   String?           @db.Text // ลิงก์กด Direct Download ตรง
  fileName        String?
  // ------------------------------------------------------------------

  // Relations
  kpiMasterId     String
  kpiMaster       KpiMaster         @relation(fields: [kpiMasterId], references: [id], onDelete: Cascade)
  
  correctiveActions KpiCorrectiveAction[]

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([kpiMasterId, month]) // 1 หัวข้อ KPI จะมีรายการบันทึกผลลัพธ์ได้แค่ 1 ช่องต่อ 1 เดือน
}

model KpiCorrectiveAction {
  id                    String           @id @default(cuid())
  sequenceNo            Int              // ครั้งที่ (รันเลข 1, 2, 3 อัตโนมัติเมื่อเพิ่มในเดือนนั้น)
  rootCauseAnalysis     String           @db.Text // การวิเคราะห์หาสาเหตุที่แท้จริง
  improvementGuidelines String           @db.Text // แนวทางการแก้ไขปรับปรุง
  responsiblePersonM365 String           // อีเมล M365 ของพนักงานผู้รับผิดชอบงานแก้ไขนี้
  dueDate               DateTime         @db.Date // กำหนดเสร็จมาตรการแก้ไขปัญหานี้

  // Relations
  kpiMonthlyResultId    String
  kpiMonthlyResult      KpiMonthlyResult @relation(fields: [kpiMonthlyResultId], references: [id], onDelete: Cascade)

  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

model KpiApprovalLog {
  id                   String          @id @default(cuid())
  month                Int             
  stepRole             KpiApprovalStep 
  actionDate           DateTime        @default(now()) 
  signatureUsedUrl     String?         @db.Text 
  signatureTypeUsed    SignatureType?  

  // Relations
  kpiMasterId          String
  kpiMaster            KpiMaster       @relation(fields: [kpiMasterId], references: [id], onDelete: Cascade)
  
  assignedUserId       String
  assignedUser         User            @relation("KpiAssignedApprover", fields: [assignedUserId], references: [id])
}