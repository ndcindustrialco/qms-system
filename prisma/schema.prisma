generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Department {
  id               String             @id @default(uuid())
  name             String             @unique
  emailGroup       String?
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  darDistributions DarDistribution[]
  darMasters       DarMaster[]
  kpiMasters       KpiMaster[]
  users            User[]
  docControls      DocumentControl[]
  docCategories    DocumentCategory[]

  @@map("Department")
}

model User {
  id                    String                    @id @default(uuid())
  employeeId            String?                   @unique
  msUserId              String?                   @unique
  name                  String?
  email                 String                    @unique
  emailVerified         DateTime?
  image                 String?
  role                  UserRole                  @default(USER)
  position              String?
  savedSignatureUrl     String?
  signatureType         SignatureType?
  departmentId          String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  announcements         Announcement[]
  darApprovals          DarApproval[]
  darAttachments        DarAttachment[]
  darMasters            DarMaster[]
  kpiApprovalLogs       KpiApprovalLog[]
  kpiObjectivesApproved KpiMaster[]               @relation("KpiObjectiveApprovedBy")
  kpiMonthlySubmitted   KpiMonthlyResult[]        @relation("KpiMonthlySubmittedBy")
  kpiMonthlyApproved    KpiMonthlyResult[]        @relation("KpiMonthlyApprovedBy")
  kpiMonthlyAttachments KpiMonthlyAttachment[]    @relation("KpiMonthlyAttachmentUploadedBy")
  kpiSignatureLogs      KpiSignatureLog[]
  kpiAuditLogs          KpiAuditLog[]
  qmsProcessings        QmsProcessing[]
  docControlsCreated    DocumentControl[]         @relation("DocCreatedBy")
  docControlsUpdated    DocumentControl[]         @relation("DocUpdatedBy")
  docRevisionsCreated   DocumentControlRevision[] @relation("DocRevCreatedBy")
  department            Department?               @relation(fields: [departmentId], references: [id])

  @@index([role])
  @@index([departmentId])
  @@map("User")
}

model SystemConfig {
  configKey   String   @id
  configValue String
  description String?
  updatedAt   DateTime @updatedAt

  @@map("SystemConfig")
}

model Announcement {
  id                  String      @id @default(uuid())
  sourceSystem        String
  title               String
  content             String
  displayType         DisplayType @default(LIST)
  pushToCompanyCenter Boolean     @default(false)
  expiryDate          DateTime?
  startDate           DateTime?
  endDate             DateTime?
  spItemId            String?
  spWebUrl            String?
  spDownloadUrl       String?
  fileName            String?
  mimeType            String?
  bgColor             String?
  bgImageUrl          String?
  bgImageSpId         String?
  textColor           String?
  status              String      @default("ACTIVE")
  createdById         String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  createdBy           User        @relation(fields: [createdById], references: [id])

  @@map("Announcement")
}

model DarMaster {
  id            String            @id @default(uuid())
  darNo         String?           @unique
  requestDate   DateTime          @default(now())
  objective     String
  docType       String
  docTypeOther  String?
  reason        String
  spFolderId    String?
  spFolderPath  String?
  spDriveId     String?
  spItemId      String?
  spWebUrl      String?
  status        DarStatus         @default(DRAFT)
  requesterId   String
  departmentId  String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  approvals     DarApproval[]
  attachments   DarAttachment[]
  distributions DarDistribution[]
  items         DarItem[]
  department    Department        @relation(fields: [departmentId], references: [id])
  requester     User              @relation(fields: [requesterId], references: [id])
  qmsProcessing QmsProcessing?

  @@index([status])
  @@index([requesterId])
  @@index([departmentId])
  @@map("DarMaster")
}

model DarItem {
  id          String    @id @default(uuid())
  itemNo      Int
  docNumber   String
  docName     String
  revision    String
  darMasterId String
  darMaster   DarMaster @relation(fields: [darMasterId], references: [id], onDelete: Cascade)

  @@map("DarItem")
}

model DarDistribution {
  id           String     @id @default(uuid())
  darMasterId  String
  departmentId String
  darMaster    DarMaster  @relation(fields: [darMasterId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id])

  @@map("DarDistribution")
}

model DarAttachment {
  id            String    @id @default(uuid())
  fileName      String
  fileSize      Int
  mimeType      String
  spItemId      String
  spWebUrl      String
  spDownloadUrl String
  folderPath    String
  darMasterId   String
  uploadedById  String
  createdAt     DateTime  @default(now())
  darMaster     DarMaster @relation(fields: [darMasterId], references: [id], onDelete: Cascade)
  uploadedBy    User      @relation(fields: [uploadedById], references: [id])

  @@index([darMasterId])
  @@index([spItemId])
  @@map("DarAttachment")
}

model DarApproval {
  id                String         @id @default(uuid())
  stepRole          ApprovalStep
  action            ApprovalAction @default(PENDING)
  actionDate        DateTime?
  signatureUsedUrl  String?
  signatureTypeUsed SignatureType?
  darMasterId       String
  assignedUserId    String
  comment           String?
  assignedUser      User           @relation(fields: [assignedUserId], references: [id])
  darMaster         DarMaster      @relation(fields: [darMasterId], references: [id], onDelete: Cascade)

  @@index([darMasterId])
  @@index([assignedUserId])
  @@map("DarApproval")
}

model QmsProcessing {
  id                    String    @id @default(uuid())
  chkHasAttachment      Boolean   @default(false)
  chkPrintAndValidate   Boolean   @default(false)
  chkRenumber           Boolean   @default(false)
  chkImpactInvestigated Boolean   @default(false)
  chkSubmitVerification Boolean   @default(false)
  chkGetBackProcess     Boolean   @default(false)
  chkCopyDistribute     Boolean   @default(false)
  comments              String?
  processDate           DateTime?
  darMasterId           String    @unique
  qmsUserId             String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  darMaster             DarMaster @relation(fields: [darMasterId], references: [id], onDelete: Cascade)
  qmsUser               User      @relation(fields: [qmsUserId], references: [id])

  @@map("QmsProcessing")
}

model PublicDocument {
  id            String   @id @default(uuid())
  darMasterId   String?
  docNumber     String
  docName       String
  revision      String
  spDriveId     String
  spItemId      String
  spFolderPath  String?
  spWebUrl      String
  publishedDate DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("PublicDocument")
}

model KpiSchedule {
  id        String   @id @default(uuid())
  year      Int
  month     Int
  dueDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month])
  @@map("KpiSchedule")
}

model KpiMaster {
  id                   String             @id @default(uuid())
  year                 Int
  periodType           KpiPeriodType      @default(YEARLY)
  objectiveDetails     String
  measurementFrequency String             @default("Every Month")
  calculationFormula   String?
  guidelines           String?
  trackingRecords      String?
  targetValue          Decimal            @db.Decimal(5, 2)
  departmentId         String
  createdById          String?
  objectiveStatus      KpiObjectiveStatus @default(DRAFT)
  version              Int                @default(1)
  approvedById         String?
  approvedAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  approvalLogs         KpiApprovalLog[]
  department           Department         @relation(fields: [departmentId], references: [id])
  approvedBy           User?              @relation("KpiObjectiveApprovedBy", fields: [approvedById], references: [id])
  monthlyResults       KpiMonthlyResult[]

  @@map("KpiMaster")
}

model KpiMonthlyResult {
  id                String                 @id @default(uuid())
  periodYear        Int?
  month             Int
  actualValue       Decimal?               @db.Decimal(5, 2)
  isNa              Boolean                @default(false)
  status            KpiMonthlyStatus       @default(PENDING)
  approvalStatus    KpiApprovalStatus      @default(DRAFT)
  spItemId          String?
  spWebUrl          String?
  spDownloadUrl     String?
  fileName          String?
  submittedById     String?
  submittedAt       DateTime?
  approvedById      String?
  approvedAt        DateTime?
  rejectionReason   String?
  closedAt          DateTime?
  kpiMasterId       String
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  correctiveActions KpiCorrectiveAction[]
  attachments       KpiMonthlyAttachment[]
  signatures        KpiSignatureLog[]
  auditLogs         KpiAuditLog[]
  submittedBy       User?                  @relation("KpiMonthlySubmittedBy", fields: [submittedById], references: [id])
  approvedBy        User?                  @relation("KpiMonthlyApprovedBy", fields: [approvedById], references: [id])
  kpiMaster         KpiMaster              @relation(fields: [kpiMasterId], references: [id], onDelete: Cascade)

  @@unique([kpiMasterId, month])
  @@unique([kpiMasterId, periodYear, month])
  @@map("KpiMonthlyResult")
}

model KpiMonthlyAttachment {
  id                 String           @id @default(uuid())
  kpiMonthlyResultId String
  fileName           String
  mimeType           String
  fileSize           Int
  spDriveId          String
  spItemId           String
  spWebUrl           String
  uploadedById       String
  createdAt          DateTime         @default(now())
  kpiMonthlyResult   KpiMonthlyResult @relation(fields: [kpiMonthlyResultId], references: [id], onDelete: Cascade)
  uploadedBy         User             @relation("KpiMonthlyAttachmentUploadedBy", fields: [uploadedById], references: [id])

  @@index([kpiMonthlyResultId])
  @@index([spItemId])
  @@map("KpiMonthlyAttachment")
}

model KpiSignatureLog {
  id                 String            @id @default(uuid())
  kpiMonthlyResultId String
  signerId           String
  signerRole         KpiSignerRole
  contentHash        String
  action             KpiWorkflowAction
  signedAt           DateTime          @default(now())
  kpiMonthlyResult   KpiMonthlyResult  @relation(fields: [kpiMonthlyResultId], references: [id], onDelete: Cascade)
  signer             User              @relation(fields: [signerId], references: [id])

  @@index([kpiMonthlyResultId])
  @@index([signerId])
  @@map("KpiSignatureLog")
}

model KpiAuditLog {
  id                 String            @id @default(uuid())
  kpiMonthlyResultId String
  actorUserId        String
  action             KpiWorkflowAction
  beforeJson         Json?
  afterJson          Json?
  createdAt          DateTime          @default(now())
  kpiMonthlyResult   KpiMonthlyResult  @relation(fields: [kpiMonthlyResultId], references: [id], onDelete: Cascade)
  actorUser          User              @relation(fields: [actorUserId], references: [id])

  @@index([kpiMonthlyResultId])
  @@index([actorUserId])
  @@map("KpiAuditLog")
}

model KpiCorrectiveAction {
  id                    String           @id @default(uuid())
  sequenceNo            Int
  rootCauseAnalysis     String
  improvementGuidelines String
  responsiblePersonM365 String
  dueDate               DateTime         @db.Date
  kpiMonthlyResultId    String
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  kpiMonthlyResult      KpiMonthlyResult @relation(fields: [kpiMonthlyResultId], references: [id], onDelete: Cascade)

  @@map("KpiCorrectiveAction")
}

model KpiApprovalLog {
  id                String          @id @default(uuid())
  month             Int
  stepRole          KpiApprovalStep
  actionDate        DateTime        @default(now())
  signatureUsedUrl  String?
  signatureTypeUsed SignatureType?
  kpiMasterId       String
  assignedUserId    String
  assignedUser      User            @relation(fields: [assignedUserId], references: [id])
  kpiMaster         KpiMaster       @relation(fields: [kpiMasterId], references: [id], onDelete: Cascade)

  @@map("KpiApprovalLog")
}

enum UserRole {
  USER
  IT
  QMS
  MR
}

enum DisplayType {
  LIST
  SCROLLING
  BANNER
}

enum DarStatus {
  DRAFT
  PENDING_REVIEW
  PENDING_APPROVE
  QMS_PROCESSING
  COMPLETED
  CANCELLED
}

enum ApprovalAction {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalStep {
  PREPARER
  REVIEWER
  APPROVER_MR
}

enum SignatureType {
  DRAW
  TYPE
  IMAGE
}

enum KpiPeriodType {
  YEARLY
  QUARTERLY
}

enum KpiMonthlyStatus {
  OK
  NG
  PENDING
}

enum KpiApprovalStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  VERIFIED
  REJECTED
}

enum KpiApprovalStep {
  PREPARER
  REVIEWER
  QMS_VERIFIER
}

enum KpiObjectiveStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ARCHIVED
}

enum KpiSignerRole {
  SUBMITTER
  APPROVER
}

enum KpiWorkflowAction {
  SUBMIT
  APPROVE
  REJECT
  CLOSE
  REOPEN
  ATTACH
  DETACH
}

model DocumentControl {
  id            String           @id @default(uuid())
  docNumber     String           @unique
  docName       String
  revision      String?
  description   String?
  status        DocControlStatus @default(DRAFT)
  effectiveDate DateTime?
  spDriveId     String?
  spItemId      String?
  spWebUrl      String?
  spDownloadUrl String?
  spFolderPath  String?
  fileName      String?
  fileSize      Int?
  mimeType      String?
  createdById   String
  updatedById   String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Relations
  createdBy    User                      @relation("DocCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?                     @relation("DocUpdatedBy", fields: [updatedById], references: [id])
  departmentId String?
  department   Department?               @relation(fields: [departmentId], references: [id])
  categoryId   String?
  category     DocumentCategory?         @relation(fields: [categoryId], references: [id])
  revisions    DocumentControlRevision[]

  @@index([status])
  @@index([categoryId])
  @@index([createdById])
  @@index([departmentId])
  @@map("DocumentControl")
}

model DocumentCategory {
  id           String   @id @default(uuid())
  name         String
  description  String?
  order        Int      @default(0)
  departmentId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department        @relation(fields: [departmentId], references: [id])
  documents  DocumentControl[]

  @@index([departmentId])
  @@map("DocumentCategory")
}

model DocumentControlRevision {
  id                String           @id @default(uuid())
  documentControlId String
  revision          String
  effectiveDate     DateTime?
  status            DocControlStatus @default(ACTIVE)
  spDriveId         String?
  spItemId          String?
  spWebUrl          String?
  spDownloadUrl     String?
  spFolderPath      String?
  fileName          String?
  fileSize          Int?
  mimeType          String?
  createdById       String
  createdAt         DateTime         @default(now())

  // Relations
  documentControl DocumentControl @relation(fields: [documentControlId], references: [id], onDelete: Cascade)
  createdBy       User            @relation("DocRevCreatedBy", fields: [createdById], references: [id])

  @@index([documentControlId])
  @@index([status])
  @@map("DocumentControlRevision")
}

enum DocControlStatus {
  DRAFT
  ACTIVE
  OBSOLETE
}
